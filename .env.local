# Local development environment variables

# Database connection
DATABASE_URL=postgresql://admin:password@localhost:5432/gear_vault
SESSION_SECRET=some-secure-random-string

# React development settings
NODE_ENV=development

# Fix for WebSocket HMR issues
WDS_SOCKET_HOST=localhost
WDS_SOCKET_PORT=0

# Force non-strict mode for React (helps with hooks errors)
VITE_DISABLE_STRICT_MODE=true

# Debug settings
DEBUG=true