# Copy this file to .env and adjust values for your environment.

# --- Required ---
# PostgreSQL connection string. The app throws on startup if this is unset.
# NOTE: Homebrew/macOS Postgres has no "postgres" role by default — it uses
# your OS username with no password. So a typical local URL looks like:
#   postgres://<your-username>@localhost:5432/gearvault
# Create the database first with:  createdb gearvault
DATABASE_URL=postgres://localhost:5432/gearvault

# --- Recommended ---
# Secret used to sign session cookies. Required in production; a dev
# fallback is used if unset. Generate one with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# --- Optional ---
# Port the server listens on (Railway sets this automatically). Defaults to 5000.
# NOTE: On macOS, port 5000 is taken by the AirPlay Receiver (Control Center),
# so use a different port locally.
PORT=5001

# Node environment: "development" enables auto-login as a dev user and seeding.
# NODE_ENV=development

# Where uploaded images are stored. Defaults to ./uploads locally.
# In production, point this at a persistent volume so uploads survive redeploys.
# On Railway: attach a Volume mounted at /data and set UPLOADS_DIR=/data/uploads
# UPLOADS_DIR=/data/uploads

# --- Google OAuth (optional; local username/password works without these) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
